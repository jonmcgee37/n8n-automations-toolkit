# ============================================
# Pattern AI Automations — n8n Configuration
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to git
# ============================================

# n8n Instance (shared team instance)
N8N_API_URL=https://pattern.app.n8n.cloud
N8N_API_KEY=your-api-key-here

# Credentials Template
# This is a workflow in n8n that contains pre-configured nodes
# with all your service credentials. The n8n plugin uses it to
# pull correct credential IDs and node configurations.
N8N_CREDENTIALS_TEMPLATE_URL=https://pattern.app.n8n.cloud/workflow/TEMPLATE_ID

# ============================================
# Project-Specific Variables (add as needed)
# ============================================
# Uncomment and fill in as your workflow requires:

# WEBHOOK_PATH=my-webhook-path
# SLACK_CHANNEL=#automation-alerts
# GOOGLE_SHEET_ID=your-sheet-id
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key
